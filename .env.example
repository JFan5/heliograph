# Copy to .env and fill in real values. .env is gitignored.

# --- Which transport to use ---
# mailgun (recommended, avoids port 25 / SMTP issues) or smtp
EMAIL_PROVIDER=mailgun

# Recipient (used if config.yaml > email.to is empty)
EMAIL_TO=you@example.com

# --- Mailgun (when EMAIL_PROVIDER=mailgun) ---
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.yourdomain.com
# from-address shown to the recipient; "Name <addr>" form works.
MAILGUN_FROM=Heliograph <noreply@yourdomain.com>
# Use the EU endpoint if your Mailgun account is in the EU region:
# MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3

# --- SMTP (when EMAIL_PROVIDER=smtp) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-account@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_FROM=Heliograph <your-account@gmail.com>

# --- Optional, used by components ---
# Personal access token raises GitHub API rate limit from 60/h to 5000/h.
GITHUB_TOKEN=
